<Window x:Class="WpfAppGraph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppGraph"
        xmlns:tabs="clr-namespace:WpfAppGraph.Views"
        xmlns:vm="clr-namespace:WpfAppGraph.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <!-- Включить вкладки в ресурсы(постепенно) -->
        
        <!-- Рисование графа -->
        <DataTemplate DataType="{x:Type vm:DrawGraphVM}">
            <tabs:DrawGraphTab/>
        </DataTemplate>

        <!-- Поиск в ширину -->
        <DataTemplate DataType="{x:Type vm:GraphBFSVM}">
            <tabs:GraphBFSTab/>
        </DataTemplate>
        
        <!-- Поиск в глубину -->
        <DataTemplate DataType="{x:Type vm:GraphDFSVM}">
            <tabs:GraphDFSTab/>
        </DataTemplate>
        
    </Window.Resources>

    <Grid>
        <TabControl ItemsSource="{Binding Tabs}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding ContentViewModel}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</Window>
