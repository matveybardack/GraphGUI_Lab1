<UserControl x:Class="WpfAppGraph.Views.DrawGraphTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             xmlns:converters="clr-namespace:WpfAppGraph.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <!-- Стиль для кнопок инструментов -->
        <Style x:Key="ToolButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="125"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="GroupName" Value="DrawingTools"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель инструментов -->
        <Border Grid.Column="0" Background="#f8f9fa" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <TextBlock Text="ГРАФ" FontSize="20" FontWeight="Black" Margin="0,0,0,20" Foreground="#2c3e50"/>

                <RadioButton Content="Вершина" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AddVertex}" Style="{StaticResource ToolButtonStyle}"/>
                <RadioButton Content="Ребро" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AddEdge}" Style="{StaticResource ToolButtonStyle}"/>
                <RadioButton Content="Целевая" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=SetTarget}" Style="{StaticResource ToolButtonStyle}"/>

                <Separator Margin="0,20"/>

                <TextBlock Text="Статистика:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding VertexCount, StringFormat='Узлов: {0}'}"/>
                <TextBlock Text="{Binding EdgeCount, StringFormat='Ребер: {0}'}"/>

                <Button Content="Очистить" Command="{Binding ResetGraphCommand}" Margin="0,30,0,0" Background="#e74c3c" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Холст -->
        <Border Grid.Column="1" Background="White">
            <local:GraphCanvasControl DataContext="{Binding}"/>
        </Border>

        <!-- Overlay Диалог (модальное окно) -->
        <Grid Grid.ColumnSpan="2" Background="#66000000" 
              Visibility="{Binding ActiveDialog, Converter={StaticResource NullToVisibilityConverter}}">
            <local:EdgeDialogControl DataContext="{Binding ActiveDialog}" 
                                     VerticalAlignment="Center" 
                                     HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>