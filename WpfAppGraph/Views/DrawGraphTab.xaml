<UserControl x:Class="WpfAppGraph.Views.DrawGraphTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             xmlns:converters="clr-namespace:WpfAppGraph.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Стиль для кнопок инструментов -->
        <Style x:Key="ToolButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="125"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="GroupName" Value="DrawingTools"/>
        </Style>

        <!-- Конвертер для Enum к bool (для RadioButton) -->
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель инструментов слева -->
        <Border Grid.Column="0" 
                BorderBrush="LightGray" 
                BorderThickness="0,0,1,0"
                Background="WhiteSmoke"
                Width="170">
            <StackPanel Margin="10">
                <TextBlock Text="Инструменты" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>

                <!-- Группа инструментов для работы с графом -->
                <TextBlock Text="Режим работы:" 
                           FontWeight="SemiBold" 
                           Margin="0,10,0,5"/>

                <RadioButton Content="Добавить вершину" 
                             Style="{StaticResource ToolButtonStyle}"
                             IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AddVertex}"/>

                <RadioButton Content="Добавить ребро" 
                             Style="{StaticResource ToolButtonStyle}"
                             IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AddEdge}"/>

                <RadioButton Content="Назначить цель" 
                             Style="{StaticResource ToolButtonStyle}"
                             IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=SetTarget}"/>

                <!-- Панель информации о графе -->
                <Border Margin="0,20,0,0" 
                        Padding="10" 
                        Background="White" 
                        BorderBrush="LightGray" 
                        BorderThickness="1"
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{Binding VertexCount, StringFormat='Вершин: {0}'}"/>
                        <TextBlock Text="{Binding EdgeCount, StringFormat='Рёбер: {0}'}"/>
                        <TextBlock Text="{Binding TargetVertexInfo, StringFormat='Целевая вершина: {0}'}" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Кнопка сброса -->
                <Button Content="Сбросить граф" 
                        Command="{Binding ResetGraphCommand}"
                        Width="120" 
                        Height="35" 
                        Margin="5,20,5,5"
                        Background="LightCoral"
                        Foreground="DarkRed"
                        FontWeight="Bold"
                        BorderBrush="DarkRed"
                        BorderThickness="1"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Основной холст для рисования графа -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Графовый холст -->
            <Border Grid.Row="1" 
                    Background="White" 
                    BorderBrush="LightGray" 
                    BorderThickness="1">
                <local:GraphCanvasControl DataContext="{Binding GraphCanvas}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>