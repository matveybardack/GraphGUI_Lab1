<UserControl x:Class="WpfAppGraph.Views.GraphDFSTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             xmlns:converters="clr-namespace:WpfAppGraph.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <!-- Стиль кнопок -->
        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- панель инструментов -->
        <Border Grid.Column="0" Background="#f8f9fa" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">

                    <TextBlock Text="Алгоритм DFS" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#2c3e50"
                           Margin="0,0,0,15"/>

                    <GroupBox Header="Режим работы" Margin="0,0,0,15" Padding="5">
                        <StackPanel>
                            <RadioButton Content="Итеративный (Стек)" 
                                     IsChecked="{Binding AlgorithmType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Iterative}"
                                     Margin="0,5"/>
                            <RadioButton Content="Рекурсивный (3 цвета)" 
                                     IsChecked="{Binding AlgorithmType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Recursive}"
                                     Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Запустить поиск" 
                        Command="{Binding StartDfsCommand}" 
                        Background="#3498db" 
                        Foreground="White"
                        Style="{StaticResource RoundedBtn}"
                        Height="35"
                        Margin="0,0,0,10"/>

                    <Button Content="Сбросить/Синхронизировать" 
                        Command="{Binding SyncGraphCommand}" 
                        Background="#e74c3c" 
                        Style="{StaticResource RoundedBtn}"
                        Height="30"
                        Margin="0,0,0,20"/>

                    <Separator Margin="0,0,0,15"/>

                    <!-- Результаты -->
                    <TextBlock Text="Результаты:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Статус:" Foreground="Gray"/>
                    <TextBlock Text="{Binding ResultStatus}" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10" 
                           TextWrapping="Wrap"/>

                    <StackPanel Visibility="{Binding IsResultAvailable, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Длина пути:" Foreground="Gray"/>
                        <TextBlock Text="{Binding PathLength, StringFormat='{}{0:F1}'}" 
                               FontWeight="Bold" 
                               FontSize="16" 
                               Foreground="#e67e22"
                               Margin="0,0,0,10"/>

                        <TextBlock Text="Найденный путь:" Foreground="Gray"/>
                        <TextBlock Text="{Binding PathString}" 
                               FontWeight="Bold" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,10"/>
                    </StackPanel>

                    <TextBlock Text="Скобочная структура:" Foreground="Gray" Margin="0,10,0,0"/>
                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                        <TextBlock Text="{Binding ParenthesisStructure}" 
                               FontFamily="Consolas" 
                               FontSize="11" 
                               TextWrapping="Wrap"
                               Foreground="#2c3e50"/>
                    </ScrollViewer>

                    <Separator Margin="0,15"/>

                    <!-- Легенда (подсказка) -->
                    <StackPanel VerticalAlignment="Bottom" Margin="0,30,0,0">
                        <TextBlock Text="Легенда:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="LightGray" Stroke="Gray"/>
                            <TextBlock Text=" - В обработке" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="LightBlue" Stroke="LightBlue"/>
                            <TextBlock Text=" - Посещена" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="LightPink" Stroke="LightPink"/>
                            <TextBlock Text=" - Завершено" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Text="Легенда Ребер:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Blue"/>
                            <TextBlock Text=" - Tree (Дерево)" FontSize="11" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Red"/>
                            <TextBlock Text=" - Back (Обратное)" FontSize="11" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Green"/>
                            <TextBlock Text=" - Forward (Прямое)" FontSize="11" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Orange"/>
                            <TextBlock Text=" - Cross (Перекрестное)" FontSize="11" Margin="5,0"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Холст -->
        <Border Grid.Column="1" Background="White">
            <local:GraphCanvasControl DataContext="{Binding GraphCanvas}"/>
        </Border>
    </Grid>
</UserControl>
