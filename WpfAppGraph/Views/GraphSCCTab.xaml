<UserControl x:Class="WpfAppGraph.Views.GraphSCCTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             xmlns:converters="clr-namespace:WpfAppGraph.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стиль для кнопок -->
        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель управления -->
        <Border Grid.Column="0" Background="#f8f9fa" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">

                    <TextBlock Text="Сильносвязанные компоненты (SCC)" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#2c3e50"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <Button Content="Найти компоненты" 
                            Command="{Binding StartSccCommand}" 
                            Background="#16a085" 
                            Style="{StaticResource RoundedBtn}"
                            Height="35"
                            Margin="0,0,0,10"/>

                    <Button Content="Сбросить результаты" 
                            Command="{Binding SyncGraphCommand}" 
                            Background="#e74c3c" 
                            Style="{StaticResource RoundedBtn}"
                            Height="30"
                            Margin="0,0,0,20"/>

                    <Separator Margin="0,0,0,15"/>

                    <!-- Результаты -->
                    <TextBlock Text="Результаты:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Статус:" Foreground="Gray"/>
                    <TextBlock Text="{Binding ResultStatus}" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10" 
                               TextWrapping="Wrap"/>

                    <StackPanel Visibility="{Binding IsResultAvailable, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Количество компонентов:" Foreground="Gray"/>
                        <TextBlock Text="{Binding ComponentCount}" 
                                   FontWeight="Bold" 
                                   FontSize="18" 
                                   Foreground="#e67e22"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Состав компонентов:" Foreground="Gray" Margin="0,5,0,0"/>
                        <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" Margin="0,5,0,0">
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto" Padding="5">
                                <TextBlock Text="{Binding ComponentsOutput}" 
                                           FontFamily="Consolas" 
                                           FontSize="12" 
                                           TextWrapping="Wrap"
                                           Foreground="#2c3e50"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <Separator Margin="0,20"/>

                    <!-- Легенда -->
                    <StackPanel>
                        <TextBlock Text="Легенда:" FontWeight="Bold" Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Ellipse Width="10" Height="10" Fill="LightGreen" Stroke="Green"/>
                            <TextBlock Text=" - Вершина определена в SCC" FontSize="11" Margin="5,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Red"/>
                            <TextBlock Text=" - Внутреннее ребро SCC" FontSize="11" Margin="5,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Gray"/>
                            <TextBlock Text=" - Связь между SCC" FontSize="11" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Text="Примечание:" FontWeight="Bold" Margin="0,10,0,0" FontSize="10"/>
                        <TextBlock Text="Вершины одного компонента помечены одинаковым номером (SCC #N)" 
                                   FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Холст -->
        <Border Grid.Column="1" Background="White">
            <local:GraphCanvasControl DataContext="{Binding GraphCanvas}"/>
        </Border>
    </Grid>
</UserControl>
