<UserControl x:Class="WpfAppGraph.Views.GraphCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             xmlns:converters="clr-namespace:WpfAppGraph.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Ваши конвертеры (без изменений) -->
        <converters:VertexStateToBrushConverter x:Key="VertexStateToBrushConverter"/>
        <converters:VertexStateToBorderBrushConverter x:Key="VertexStateToBorderBrushConverter"/>
        <converters:EdgeTypeToBrushConverter x:Key="EdgeTypeToBrushConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Шаблон вершины (УБРАЛИ Canvas.Left/Top отсюда) -->
        <DataTemplate x:Key="VertexTemplate">
            <Grid Width="40" Height="40">
                <Ellipse x:Name="Circle" Fill="{Binding State, Converter={StaticResource VertexStateToBrushConverter}}" 
                 Stroke="{Binding State, Converter={StaticResource VertexStateToBorderBrushConverter}}" StrokeThickness="2"/>
                <StackPanel VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="{Binding Label}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                    <TextBlock Text="{Binding IterationInfo}" HorizontalAlignment="Center" FontSize="9" Foreground="#555555" Margin="0,-2,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Шаблон ребра (без изменений) -->
        <DataTemplate x:Key="EdgeTemplate">
            <Grid>
                <Line IsHitTestVisible="False"
                      X1="{Binding X1}" Y1="{Binding Y1}"
                      X2="{Binding X2}" Y2="{Binding Y2}"
                      StrokeThickness="2"
                      Stroke="{Binding Type, Converter={StaticResource EdgeTypeToBrushConverter}}"/>

                <Path IsHitTestVisible="False"
                      Data="{Binding ArrowGeometry}"
                      Stroke="{Binding Type, Converter={StaticResource EdgeTypeToBrushConverter}}"
                      Fill="{Binding Type, Converter={StaticResource EdgeTypeToBrushConverter}}"
                      Visibility="{Binding IsDirected, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <TextBlock Text="{Binding Weight, StringFormat={}{0:F1}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Background="White" Padding="2,1" FontWeight="Bold" FontSize="10"
                           IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="{Binding LabelX}" Y="{Binding LabelY}"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- ИСПРАВЛЕНИЕ 1: Обработчик клика прямо на корневом Grid. 
         Background="Transparent" обязателен, чтобы Grid ловил клики по пустому месту. -->
    <Grid Background="Transparent" MouseLeftButtonDown="MainCanvas_MouseLeftButtonDown">

        <!-- Слой 1: Ребра -->
        <ItemsControl ItemsSource="{Binding Edges}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource EdgeTemplate}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Слой 2: Вершины -->
        <ItemsControl ItemsSource="{Binding Vertices}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- ИСПРАВЛЕНИЕ 2: ItemContainerStyle! 
                 Это заставляет сам контейнер элемента позиционироваться на Canvas -->
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Кнопка теперь просто лежит внутри контейнера, который уже сдвинут -->
                    <Button Command="{Binding DataContext.VertexClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource VertexTemplate}"/>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- УБРАЛИ лишний ClickCanvas снизу, теперь клики ловит Grid -->
    </Grid>
</UserControl>