<UserControl x:Class="WpfAppGraph.Views.GraphFCycleTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             xmlns:converters="clr-namespace:WpfAppGraph.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель инструментов -->
        <Border Grid.Column="0" Background="#f8f9fa" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">

                    <TextBlock Text="Фундаментальные циклы" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#2c3e50"
                               Margin="0,0,0,15"/>

                    <GroupBox Header="Алгоритм построения остова" Margin="0,0,0,15" Padding="5">
                        <StackPanel>
                            <RadioButton Content="BFS" 
                                         IsChecked="{Binding AlgorithmType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=BFS}"
                                         Margin="0,5"/>
                            <RadioButton Content="DFS" 
                                         IsChecked="{Binding AlgorithmType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=DFS}"
                                         Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Найти цикл" 
                            Command="{Binding StartFundamentalCommand}" 
                            Background="#e67e22" 
                            Style="{StaticResource RoundedBtn}"
                            Height="35"
                            Margin="0,0,0,10"/>

                    <Button Content="Сбросить/Синхронизировать" 
                            Command="{Binding SyncGraphCommand}" 
                            Background="#e74c3c" 
                            Style="{StaticResource RoundedBtn}"
                            Height="30"
                            Margin="0,0,0,20"/>

                    <Separator Margin="0,0,0,15"/>

                    <TextBlock Text="Результаты:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Статус:" Foreground="Gray"/>
                    <TextBlock Text="{Binding ResultStatus}" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10" 
                               TextWrapping="Wrap"/>

                    <StackPanel Visibility="{Binding IsResultAvailable, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Состав:" Foreground="Gray"/>
                        <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" Margin="0,5,0,0">
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto" Padding="5">
                                <TextBlock Text="{Binding ComponentsOutput}" 
                                           FontWeight="Bold" 
                                           TextWrapping="Wrap"
                                           Foreground="#2c3e50"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <Separator Margin="0,20"/>

                    <StackPanel>
                        <TextBlock Text="Легенда:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="20" Height="3" Fill="Red"/>
                            <TextBlock Text=" - Пройденное ребро" FontSize="11" Margin="5,0"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Холст -->
        <Border Grid.Column="1" Background="White">
            <local:GraphCanvasControl DataContext="{Binding GraphCanvas}"/>
        </Border>
    </Grid>
</UserControl>
