<UserControl x:Class="WpfAppGraph.Views.EdgeDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppGraph.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="White" BorderBrush="#34495e" BorderThickness="2" CornerRadius="12" Padding="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Настройка ребра" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Вес (длина):" FontSize="12" Foreground="Gray"/>
            <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Padding="5"/>

            <CheckBox IsChecked="{Binding IsDirected}" Content="Ориентированное" Margin="0,5,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Content="Отмена" Command="{Binding CancelCommand}" Margin="5" Padding="5"/>
                <Button Content="Создать" Command="{Binding ConfirmCommand}" Grid.Column="1" Margin="5" Padding="5" 
                        Background="#3498db" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
